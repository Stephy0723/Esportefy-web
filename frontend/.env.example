# Variables de entorno para el frontend
# Copia este archivo como .env y ajusta los valores para tu entorno

# URL del backend principal (API REST)
VITE_API_URL=http://localhost:4000

# URL del servicio de chat (Socket.io)
VITE_CHAT_URL=http://localhost:5001

# Modo de revisión Riot (frontend): deshabilita opciones de registro pagado/invitación/password
VITE_RIOT_REVIEW_MODE=false

# Mínimo recomendado por policy para torneos Riot (participants activos)
VITE_RIOT_MIN_ACTIVE_PARTICIPANTS=20

# Modo beta MLBB (frontend): fuerza validaciones legales estrictas en creación/edición
VITE_MLBB_BETA_MODE=true

# Polling del módulo de amigos (ms). Mantiene la vista social actualizada sin recargar.
VITE_SOCIAL_POLL_MS=20000
