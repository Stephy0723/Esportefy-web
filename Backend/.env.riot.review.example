NODE_ENV=production
PORT=4000

# Frontend de review (HTTPS)
FRONTEND_URL=https://review.tudominio.com
CORS_ORIGINS=https://review.tudominio.com

# Base de datos y sesión
MONGO_URI=mongodb://localhost:27017/esportify-web
JWT_SECRET=cambia-esto-en-produccion
AUTH_TOKEN_TTL=30d
AUTH_TOKEN_REMEMBER_TTL=90d

# Correo (OTP Riot y notificaciones)
EMAIL_USER=tu-correo@gmail.com
EMAIL_PASS=tu-app-password

# Riot review mode
RIOT_API_KEY=tu-riot-api-key
RIOT_KEY_MODE=development
ALLOW_RIOT_DEV_KEY_IN_PROD=false
RIOT_REVIEW_MODE=true
RIOT_TOURNAMENT_MIN_ACTIVE_PARTICIPANTS=20

# Opcional: callback de Tournament API (cuando habilites ese flujo)
RIOT_TOURNAMENT_REGION=
RIOT_TOURNAMENT_CALLBACK=
