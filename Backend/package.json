{
  "name": "glitchgang-api",
  "version": "1.0.0",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "test": "jest --watchAll --no-cache",
    "test:e2e:mlbb": "node --env-file=.env scripts/e2e/mlbb-flow-smoke.js",
    "test:e2e:riot": "RIOT_REVIEW_MODE=true node scripts/e2e/riot-review-smoke.js",
    "test:e2e:auth": "node scripts/e2e/auth-session-smoke.js",
    "test:e2e:teams": "node scripts/e2e/team-flow-smoke.js",
    "test:e2e:social": "node scripts/e2e/social-flow-smoke.js",
    "test:e2e:university": "node scripts/e2e/university-flow-smoke.js",
    "test:load:mlbb": "node --env-file=.env scripts/load/mlbb-load-smoke.js",
    "test:load:mlbb:writes": "node --env-file=.env scripts/load/mlbb-write-load-smoke.js",
    "seed:demo": "node --env-file=.env scripts/seed-demo-users.js",
    "reset:db": "node --env-file=.env scripts/reset-database.js",
    "normalize:countries": "node --env-file=.env scripts/normalize-user-countries.js",
