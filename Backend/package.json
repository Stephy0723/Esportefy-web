    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "form-data": "^4.0.5",
    "helmet": "^8.1.0",
    "ioredis": "^5.7.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.20.2",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.11",
    "otplib": "^13.3.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
