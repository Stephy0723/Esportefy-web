PORT = 4000
FRONTEND_URL = http://localhost:5173
CORS_ORIGINS = http://localhost:5173,http://localhost:3000
MONGO_URI = mongodb://localhost:27017/esportify-web
JWT_SECRET = ponerunaclaveaqui
EMAIL_USER = tu-correo@gmail.com
EMAIL_PASS = tu-contraseña-de-aplicación
DISCORD_CLIENT_ID=xxxxxxxx
DISCORD_CLIENT_SECRET=xxxxxxxx
DISCORD_REDIRECT_URI=http://localhost:4000/api/auth/discord/callback
RIOT_API_KEY = xxxxxxxxxxxxx
# development | production
RIOT_KEY_MODE = development
# Solo para entornos controlados. No habilitar en despliegues públicos.
ALLOW_RIOT_DEV_KEY_IN_PROD = false
# Activa modo prototipo para revisión Riot: fuerza torneos con inscripción gratuita.
RIOT_REVIEW_MODE = false
# Mínimo de participantes activos para iniciar torneos Riot (default recomendado por policy: 20)
RIOT_TOURNAMENT_MIN_ACTIVE_PARTICIPANTS = 20
RIOT_TOURNAMENT_REGION=xxx
RIOT_TOURNAMENT_CALLBACK=https://TU_BACKEND_PUBLICO/api/riot/tournament/callback

# MLBB verification flow
# manual: deja solicitudes en revisión
# auto: aprueba automáticamente (útil para beta masiva)
MLBB_VERIFICATION_MODE = manual
# Correo donde llegan solicitudes MLBB (si manual)
MLBB_REVIEW_EMAIL = tu-correo-equipo@gmail.com
# Cooldown anti-spam para reenvío de solicitud MLBB (segundos)
MLBB_LINK_COOLDOWN_SECONDS = 90
# Riesgo: máximo de intentos de vinculación en 24h antes de forzar revisión manual
MLBB_RISK_MAX_ATTEMPTS_24H = 4
# Si una cuenta fue rechazada, tiempo mínimo antes de permitir reintento sin señal de riesgo (minutos)
MLBB_REJECT_RETRY_COOLDOWN_MINUTES = 120
# Cola de correos MLBB
MLBB_EMAIL_QUEUE_ENABLED = true
MLBB_EMAIL_QUEUE_POLL_MS = 5000
MLBB_EMAIL_QUEUE_BATCH_SIZE = 20
MLBB_EMAIL_QUEUE_MAX_ATTEMPTS = 5
# Modo beta legal MLBB: obliga torneos gratuitos y validaciones extra de cumplimiento
MLBB_BETA_MODE = true
# Mínimo de equipos aprobados para iniciar torneos MLBB
MLBB_MIN_APPROVED_TEAMS = 2
# Modo estricto: exige titulares vinculados a usuarios reales de Esportefy
MLBB_REQUIRE_LINKED_STARTERS = true

# University / Microsoft Entra verification
# Por ahora el flujo automático está restringido a universidades de RD habilitadas en la app.
# Cada universidad debe coincidir con sus dominios institucionales oficiales configurados en la allowlist.
# Usa "organizations" para aceptar solo cuentas laborales/escolares, no cuentas personales Microsoft.
MICROSOFT_TENANT_AUTHORITY = organizations
MICROSOFT_CLIENT_ID = xxxxxxxx
MICROSOFT_CLIENT_SECRET = xxxxxxxx
MICROSOFT_REDIRECT_URI = http://localhost:4000/api/university/microsoft/callback
# Si el correo institucional de la postulación coincide exactamente con la cuenta Microsoft/Entra conectada,
# la verificación universitaria puede aprobarse automáticamente.
UNIVERSITY_AUTO_APPROVE_EMAIL_MATCH = true
# Override opcional por universidad.
# Ejemplo:
# UNIVERSITY_VERIFICATION_RULES_JSON = {"uasd":{"allowedDomains":["uasd.edu.do"],"allowedTenantIds":["xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"]}}
UNIVERSITY_VERIFICATION_RULES_JSON =
