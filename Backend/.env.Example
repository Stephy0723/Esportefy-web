# API_BASE_URL = http://localhost:4000
# E2E_PLAYER_EMAIL = player@mail.com
# E2E_PLAYER_PASSWORD = Password123!
# E2E_PLAYER_TOKEN = <token-opcional-si-no-quieres-login>
# E2E_ADMIN_EMAIL = admin@mail.com
# E2E_ADMIN_PASSWORD = Password123!
# E2E_ADMIN_TOKEN = <token-opcional-si-hay-revisión-manual>
# E2E_MLBB_PLAYER_ID = 123456789
# E2E_MLBB_ZONE_ID = 1234
# E2E_MLBB_IGN = ProPlayer
#
# LOAD:
# LOAD_AUTH_TOKEN = <token-opcional>
# LOAD_EMAIL = player@mail.com
# LOAD_PASSWORD = Password123!
# LOAD_METHOD = GET
# LOAD_PATH = /api/auth/mlbb/status
# LOAD_TOTAL_REQUESTS = 500
# LOAD_CONCURRENCY = 100
# LOAD_MAX_FAILURE_RATE = 0.05
