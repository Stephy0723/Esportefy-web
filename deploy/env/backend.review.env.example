NODE_ENV=production
PORT=4000

# Frontend review URL
FRONTEND_URL=https://glitchgang.net
CORS_ORIGINS=https://glitchgang.net
AUTH_COOKIE_DOMAIN=.glitchgang.net
AUTH_COOKIE_NAME=auth_token
CSRF_COOKIE_NAME=csrf_token
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=none
AUTH_TOKEN_TTL=30d
AUTH_TOKEN_REMEMBER_TTL=90d

# Database / auth
MONGO_URI=mongodb://127.0.0.1:27017/glitchgang
JWT_SECRET=cambia-esto-por-un-secreto-largo

# Email
EMAIL_USER=ops@glitchgang.net
EMAIL_PASS=tu-password-de-aplicacion

# Discord (si aplica en review)
DISCORD_CLIENT_ID=xxxxxxxx
DISCORD_CLIENT_SECRET=xxxxxxxx
DISCORD_REDIRECT_URI=https://api.glitchgang.net/api/auth/discord/callback

# Riot review
RIOT_API_KEY=tu-riot-api-key
RIOT_KEY_MODE=development
# Solo mientras el review build esté restringido con basic auth o allowlist.
ALLOW_RIOT_DEV_KEY_IN_PROD=true
RIOT_REVIEW_MODE=true
RIOT_TOURNAMENT_MIN_ACTIVE_PARTICIPANTS=20
RIOT_TOURNAMENT_REGION=americas
RIOT_TOURNAMENT_CALLBACK=https://api.glitchgang.net/api/riot/tournament/callback

# Riot Sign On / VALORANT
RIOT_RSO_CLIENT_ID=
RIOT_RSO_CLIENT_SECRET=
RIOT_RSO_REDIRECT_URI=https://api.glitchgang.net/api/auth/riot/valorant/callback
RIOT_RSO_AUTHORIZE_URL=https://auth.riotgames.com/authorize
RIOT_RSO_TOKEN_URL=https://auth.riotgames.com/token
RIOT_RSO_ACCOUNT_ME_URL=https://americas.api.riotgames.com/riot/account/v1/accounts/me
RIOT_RSO_SCOPES=openid offline_access

# MLBB (si mantienes el mismo backend)
MLBB_VERIFICATION_MODE=manual
MLBB_REVIEW_EMAIL=ops@glitchgang.net
MLBB_LINK_COOLDOWN_SECONDS=90
# Para una review Riot estándar no hace falta correr la cola MLBB.
MLBB_EMAIL_QUEUE_ENABLED=false
MLBB_EMAIL_QUEUE_POLL_MS=5000
MLBB_EMAIL_QUEUE_BATCH_SIZE=20
MLBB_EMAIL_QUEUE_MAX_ATTEMPTS=5
MLBB_BETA_MODE=true
MLBB_MIN_APPROVED_TEAMS=2
MLBB_REQUIRE_LINKED_STARTERS=true
